# Copy to ".env" and paste your key from:
# https://www.themoviedb.org/settings/api
#
# Vite only exposes variables prefixed with VITE_
# Primary env name for this app (Web Cinema); avoids clashing with other projects:
VITE_NEXORA_TMDB_API_KEY=
# Legacy alias (optional if you already use this name):
# VITE_TMDB_API_KEY=
